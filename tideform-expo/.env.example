# ─────────────────────────────────────────────────────────────────────────────
# Tideform (Expo) environment.
# Copy to `.env` and fill in. Anything prefixed EXPO_PUBLIC_ is inlined into the
# JS bundle at build time (Expo convention) and is therefore PUBLIC — never put
# secrets here. All privileged secrets (sponsor key, custodial key) live ONLY in
# the Zentos backend (https://tidalform.xyz). The mobile app is a thin client.
#
# Every value below has a sane MAINNET default baked into lib/env.ts, so the app
# runs out of the box even with this file empty. Override to point at testnet or
# a self-hosted Zentos.
# ─────────────────────────────────────────────────────────────────────────────

# Sui network the read-side fullnode client targets: mainnet | testnet | devnet | localnet
EXPO_PUBLIC_SUI_NETWORK=mainnet

# tideform package — `published-at` ID, used as the target prefix for moveCalls.
# MAINNET: 0xeafe4800dc71923b1e743f199738aa85fbdc6c8cec55ff138f0d69ee6da72dd4
EXPO_PUBLIC_TIDEFORM_PACKAGE_ID=0xeafe4800dc71923b1e743f199738aa85fbdc6c8cec55ff138f0d69ee6da72dd4

# tideform `original-id` — used for event TYPE queries (event type-origin is stable
# across package upgrades; published-at is not). On v1 these are identical.
# MAINNET: 0xeafe4800dc71923b1e743f199738aa85fbdc6c8cec55ff138f0d69ee6da72dd4
EXPO_PUBLIC_TIDEFORM_ORIGINAL_PACKAGE_ID=0xeafe4800dc71923b1e743f199738aa85fbdc6c8cec55ff138f0d69ee6da72dd4

# Walrus aggregator (public, no auth) for reading blobs straight from the device.
# MAINNET: https://aggregator.walrus-mainnet.walrus.space
# TESTNET: https://aggregator.walrus-testnet.walrus.space
EXPO_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-mainnet.walrus.space

# Zentos backend base URL (custodial auth + sponsored signing + sponsored Walrus
# upload). Defaults to the live deployment so the app works out of the box.
# Override to a self-hosted Zentos or http://localhost:3000 for local dev.
EXPO_PUBLIC_BACKEND_BASE_URL=https://tidalform.xyz

# Google OAuth client ID used by expo-auth-session for native Google sign-in.
# Use the iOS/Android/Web client ID(s) from your Google Cloud OAuth consent app.
# (No real default — supply your own.)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Seal key server object IDs (comma-separated). Mainnet free public key server,
# threshold 1:
# 0x4a65b4ff7ba8f4b538895ee35959f982a95f0db7e2a202ec989d261ea927286a
EXPO_PUBLIC_SEAL_KEY_SERVERS=0x4a65b4ff7ba8f4b538895ee35959f982a95f0db7e2a202ec989d261ea927286a

# Seal decryption threshold (number of key-server shares required). Mainnet: 1
EXPO_PUBLIC_SEAL_THRESHOLD=1
