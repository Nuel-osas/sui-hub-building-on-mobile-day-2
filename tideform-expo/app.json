{
  "expo": {
    "name": "Tideform",
    "slug": "tideform-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tideform",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "xyz.tidalform.tideform"
    },
    "android": {
      "package": "xyz.tidalform.tideform",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
